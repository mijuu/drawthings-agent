{
  "name": "drawthings",
  "version": "1.0.0",
  "description": "Draw Things AI image generation for OpenClaw",
  "main": "scripts/generate.js",
  "bin": {
    "dtgen": "./scripts/generate.js"
  },
  "scripts": {
    "generate": "node scripts/generate.js",
    "health": "node scripts/generate.js --health",
    "models": "node scripts/generate.js --list-models",
    "server:start": "node scripts/start-server.js",
    "server:stop": "node scripts/stop-server.js",
    "server:status": "node scripts/generate.js --health"
  },
  "keywords": [
    "drawthings",
    "ai",
    "image-generation",
    "grpc"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@grpc/grpc-js": "^1.12.6",
    "@grpc/proto-loader": "^0.7.13",
    "commander": "^13.1.0",
    "flatbuffers": "^25.9.23",
    "pngjs": "^7.0.0"
  }
}
