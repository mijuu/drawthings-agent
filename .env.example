# Draw Things gRPC Server Configuration
# Copy this file to .env and fill in your local paths

# Path to the Draw Things gRPC server binary
DRAWTHINGS_SERVER_PATH=/path/to/your/gRPCServerCLI-macOS

# Path to the directory containing your models
DRAWTHINGS_MODELS_PATH=~/Library/Containers/com.liuliu.draw-things/Data/Documents/Models

# Optional: Server address (default: 127.0.0.1:7859)
DRAWTHINGS_SERVER_ADDR=127.0.0.1:7859

# Optional: Use TLS/SSL for gRPC (default: true)
# When true, the client will use SSL and the server will NOT use --no-tls
DRAWTHINGS_USE_TLS=true
